// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum ExtractionJobStatus {
  queued
  running
  succeeded
  failed
  blocked_robots
}

enum ExtractionJobStep {
  normalize
  robots
  extract
  persist
  complete
}

enum ExtractionMethod {
  jina
  readability
  playwright
  unknown
}

model User {
  id           String        @id // Uses Supabase Auth UUID, no default
  email        String        @unique
  createdAt    DateTime      @default(now())
  articles     Article[]
  userArticles UserArticle[]

  @@map("users")
}

model Article {
  id           String        @id @default(cuid())
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  title        String
  content      String        @db.Text
  summary      String        @db.Text
  takeaways    String[]
  outline      Json?
  createdAt    DateTime      @default(now())
  chunks       Chunk[]
  userArticles UserArticle[]

  @@index([userId, createdAt])
  @@index([url])
  @@map("articles")
}

model UserArticle {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId, createdAt])
  @@index([articleId])
  @@map("user_articles")
}

model Chunk {
  id         String                       @id @default(cuid())
  articleId  String
  article    Article                      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content    String                       @db.Text
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int

  @@index([articleId])
  @@map("chunks")
}

model ExtractionJob {
  id           String              @id @default(cuid())
  sourceUrl    String
  canonicalUrl String
  domain       String
  status       ExtractionJobStatus @default(queued)
  step         ExtractionJobStep   @default(normalize)
  attemptCount Int                 @default(0)
  errorCode    String?
  errorMessage String?             @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  completedAt  DateTime?
  result       ExtractionResult?

  @@index([status, createdAt])
  @@index([domain, createdAt])
  @@index([canonicalUrl])
  @@map("extraction_jobs")
}

model ExtractionResult {
  id              String           @id @default(cuid())
  extractionJobId String           @unique
  extractionJob   ExtractionJob    @relation(fields: [extractionJobId], references: [id], onDelete: Cascade)
  title           String
  contentText     String           @db.Text
  excerpt         String?          @db.Text
  author          String?
  siteName        String?
  method          ExtractionMethod @default(unknown)
  qualityScore    Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([method])
  @@map("extraction_results")
}

model DomainPolicy {
  domain         String   @id
  robotsAllowed  Boolean  @default(true)
  maxRps         Float    @default(1)
  maxConcurrency Int      @default(1)
  blockReason    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("domain_policies")
}

model RobotsCache {
  domain     String   @id
  robotsBody String   @db.Text
  fetchedAt  DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
  @@map("robots_cache")
}
